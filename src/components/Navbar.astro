---
---

<header class="nav">
  <div class="container nav-inner">
    <a href="#top" class="brand" aria-label="NEXIA 2026 — Inicio">
      <span class="brand-mark">
        <svg width="28" height="28" viewBox="0 0 64 64" aria-hidden="true">
          <defs>
            <linearGradient id="navg" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="var(--primary)" />
              <stop offset="100%" stop-color="var(--accent)" />
            </linearGradient>
          </defs>
          <path d="M16 48 V16 L32 38 V16 H40 V48 L24 26 V48 Z" fill="url(#navg)"/>
        </svg>
      </span>
      <div class="brand-text">
        <span class="brand-name">NEXIA</span>
        <span class="brand-year">2026</span>
      </div>
    </a>

    <nav class="nav-links" aria-label="Principal">
      <a href="#about">Sobre el evento</a>
      <a href="#stats">Cifras</a>
      <a href="#schedule">Agenda</a>
      <a href="#tracks">Tracks</a>
      <a href="#speakers">Ponentes</a>
      <a href="#sponsors">Aliados</a>
      <a href="#certifications">Certificaciones</a>
      <a href="#faq">FAQ</a>
    </nav>

    <a href="#register" class="btn btn-primary nav-cta">
      Postular
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 16px 0;
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    background: color-mix(in srgb, var(--bg-0) 65%, transparent);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--glow);
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .brand-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800;
    font-size: 18px;
    letter-spacing: 0.05em;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .brand-year {
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-dim);
    letter-spacing: 0.2em;
    margin-top: 2px;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    font-size: 14px;
    color: var(--text-dim);
  }

  .nav-links a {
    position: relative;
    transition: color 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--primary);
    transition: width 0.3s ease;
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-cta {
    padding: 10px 20px;
    font-size: 14px;
  }

  @media (max-width: 880px) {
    .nav-links { display: none; }
  }

  @media (max-width: 480px) {
    .nav-cta span { display: none; }
  }
</style>
