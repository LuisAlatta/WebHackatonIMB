              </defs>
              <path d="M16 48 V16 L32 38 V16 H40 V48 L24 26 V48 Z" fill="url(#footerg)"/>
            </svg>
          </span>
          <div>
            <div class="brand-name">NEXIA 2026</div>
            <div class="brand-sub">Build with AI · Hackathon</div>
          </div>
        </div>
        <p class="footer-text">
          El primer hackathon universitario presencial de Arequipa 100% enfocado
          en IA para transformar la educación.
        </p>
        <div class="contact-bits">
          <a href="mailto:nexia2026@imb.pe" class="bit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            nexia2026@imb.pe
          </a>
          <a href="tel:+51993426785" class="bit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +51 993 426 785
          </a>
          <span class="bit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Arequipa, Perú
          </span>
        </div>

        <div class="press-card glass">
          <span class="press-tag mono">// PRENSA · RR.PP.</span>
          <span class="press-name">Sadday Rojas Medina</span>
          <span class="press-role">Relacionista Público · Marca Peruana S.A.C.</span>
          <a href="tel:+51993426785" class="press-phone mono">+51 993 426 785</a>
        </div>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <h4>Evento</h4>
          <a href="#about">Sobre NEXIA</a>
          <a href="#schedule">Agenda</a>
          <a href="#tracks">Tracks</a>
          <a href="#speakers">Ponentes</a>
          <a href="#certifications">Certificaciones</a>
          <a href="#register">Postulaciones</a>
        </div>
        <div class="footer-col">
          <h4>Aliados</h4>
          <a href="#sponsors">IMB Institute</a>
          <a href="#sponsors">GDG Arequipa</a>
          <a href="#sponsors">ISUR</a>
          <a href="#sponsors">IEEE <span class="tba mono">tba</span></a>
        </div>
        <div class="footer-col">
          <h4>Contacto</h4>
          <a href="mailto:nexia2026@imb.pe">Email oficial</a>
          <a href="#">Prensa</a>
          <a href="#">Patrocinios</a>
          <a href="#">Voluntariado</a>
        </div>
        <div class="footer-col">
          <h4>Comunidad</h4>
          <a href="#" aria-label="Instagram">Instagram</a>
          <a href="#" aria-label="LinkedIn">LinkedIn</a>
          <a href="#" aria-label="Facebook">Facebook</a>
          <a href="#" aria-label="WhatsApp">WhatsApp</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-mini-logos" aria-label="Aliados">
        <span class="mini-logo" title="IMB Institute"><img src="/logos/imb%20icon.jpg" alt="IMB Institute" loading="lazy"/></span>
        <span class="mini-logo" title="GDG Arequipa"><img src="/logos/gdg%20icon.png" alt="GDG Arequipa" loading="lazy"/></span>
        <span class="mini-logo" title="ISUR — Aliado Estratégico y Coorganizador"><img src="/logos/isur%20icon.png" alt="ISUR" loading="lazy"/></span>
        <span class="mini-divider"></span>
        <span class="mini-meta mono">Organizado por IMB · GDG · ISUR</span>
      </div>
      <span class="copy mono">
        © 2026 IMB Institute · NEXIA 2026 · Arequipa, Perú
      </span>
      <span class="version mono">v1.0 · build with AI</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    padding: 80px 0 0;
    border-top: 1px solid var(--border);
    overflow: hidden;
  }

  .footer .container {
    position: relative;
    z-index: 1;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 60px;
    padding-bottom: 60px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .brand-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: 0.04em;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .brand-sub {
    font-size: 12px;
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.1em;
    margin-top: 2px;
  }

  .footer-text {
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 380px;
  }

  .tba {
    margin-left: 6px;
    font-size: 9px;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--surface-strong);
    color: var(--text-dim);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .press-card {
    margin-top: 24px;
    padding: 16px 18px;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: 380px;
  }

  .press-tag {
    font-size: 10px;
    color: var(--primary);
    letter-spacing: 0.18em;
  }

  .press-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-top: 2px;
  }

  .press-role {
    font-size: 12px;
    color: var(--text-dim);
  }

  .press-phone {
    margin-top: 6px;
    font-size: 12px;
    color: var(--primary);
  }

  .contact-bits {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bit {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.3s ease;
  }

  a.bit:hover {
    color: var(--primary);
  }

  .bit svg {
    color: var(--primary);
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .footer-col h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 18px;
    letter-spacing: 0.05em;
  }

  .footer-col a {
    display: block;
    font-size: 13px;
    color: var(--text-dim);
    padding: 6px 0;
    transition: color 0.3s ease;
  }

  .footer-col a:hover {
    color: var(--primary);
  }

  .footer-bottom {
    padding: 24px 0;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--text-dim);
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-mini-logos {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .mini-logo {
    width: 30px;
    height: 30px;
    background: transparent;
    border-radius: 8px;
    padding: 0;
    overflow: hidden;
    display: grid;
    place-items: center;
  }

  .mini-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .mini-divider {
    width: 1px;
    height: 18px;
    background: var(--border);
    margin: 0 4px;
  }

  .mini-meta {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }

  .footer-mega {
    position: absolute;
    left: 50%;
    bottom: -2vw;
    transform: translateX(-50%);
    width: 100%;
    text-align: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(6rem, 22vw, 16rem);
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -0.04em;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    opacity: 0.12;
    z-index: 0;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .footer-top { grid-template-columns: 1fr; gap: 40px; }
    .footer-cols { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .footer-cols { grid-template-columns: 1fr 1fr; gap: 24px; }
  }
</style>
