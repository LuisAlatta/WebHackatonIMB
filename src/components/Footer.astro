      </div>

      <div class="footer-mega" aria-hidden="true">NEXIA</div>
    </div>

    <div class="footer-bottom">
      <div class="footer-mini-logos" aria-label="Aliados">
        <span class="mini-logo" title="IMB Institute"><img src="/logos/imb%20icon.jpg" alt="IMB Institute" loading="lazy"/></span>
        <span class="mini-logo" title="GDG Arequipa"><img src="/logos/gdg%20icon.png" alt="GDG Arequipa" loading="lazy"/></span>
        <span class="mini-logo" title="ISUR — Aliado Estratégico y Coorganizador"><img src="/logos/isur%20icon.png" alt="ISUR" loading="lazy"/></span>
        <span class="mini-divider"></span>
        <span class="mini-meta mono">Organizado por IMB · GDG · ISUR</span>
      </div>
      <span class="copy mono">
        © 2026 IMB Institute · NEXIA 2026 · Arequipa, Perú
      </span>
      <span class="version mono">v1.0 · build with AI</span>
    </div>
