</footer>

<style>
  .footer {
    position: relative;
    padding: 80px 0 0;
    border-top: 1px solid var(--border);
    overflow: hidden;
  }

  .footer .container {
    position: relative;
    z-index: 1;
  }

  .footer-top {
    position: relative;
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 60px;
    padding-bottom: 60px;
  }

  .footer-brand,
  .footer-cols {
    position: relative;
    z-index: 1;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .brand-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: 0.04em;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .brand-sub {
    font-size: 12px;
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.1em;
    margin-top: 2px;
  }

  .footer-text {
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 380px;
  }

  .tba {
    margin-left: 6px;
    font-size: 9px;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--surface-strong);
    color: var(--text-dim);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .press-card {
    margin-top: 24px;
    padding: 16px 18px;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: 380px;
  }

  .press-tag {
    font-size: 10px;
    color: var(--primary);
    letter-spacing: 0.18em;
  }

  .press-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-top: 2px;
  }

  .press-role {
    font-size: 12px;
    color: var(--text-dim);
  }

  .press-phone {
    margin-top: 6px;
    font-size: 12px;
    color: var(--primary);
  }

  .contact-bits {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bit {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.3s ease;
  }

  a.bit:hover {
    color: var(--primary);
  }

  .bit svg {
    color: var(--primary);
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .footer-col h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 18px;
    letter-spacing: 0.05em;
  }

  .footer-col a {
    display: block;
    font-size: 13px;
    color: var(--text-dim);
    padding: 6px 0;
    transition: color 0.3s ease;
  }

  .footer-col a:hover {
    color: var(--primary);
  }

  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  .social-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-dim);
    padding: 0;
    transition: color 0.25s ease, border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }

  .social-icon:hover {
    color: var(--primary);
    border-color: color-mix(in srgb, var(--primary) 50%, transparent);
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    transform: translateY(-2px);
    box-shadow: 0 0 24px color-mix(in srgb, var(--primary) 35%, transparent);
  }

  .social-icon svg {
    display: block;
  }

  .footer-bottom {
    padding: 24px 0;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--text-dim);
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-mini-logos {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .mini-logo {
    width: 30px;
    height: 30px;
    background: transparent;
    border-radius: 8px;
    padding: 0;
    overflow: hidden;
    display: grid;
    place-items: center;
  }

  .mini-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .mini-divider {
    width: 1px;
    height: 18px;
    background: var(--border);
    margin: 0 4px;
  }

  .mini-meta {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }

  .footer-mega {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    width: 100%;
    text-align: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(5rem, 18vw, 14rem);
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -0.04em;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    opacity: 0.14;
    z-index: 0;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  @media (max-width: 980px) {
    .footer-top { grid-template-columns: 1fr; gap: 40px; }
    .footer-cols { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .footer-cols { grid-template-columns: 1fr 1fr; gap: 24px; }
  }
</style>
