---
const benefits = [
  'Certificado oficial avalado por IMB Institute, GDG Arequipa · IEEE (por confirmar)',
  'Mentoría con expertos de la industria y la academia',
  'Acceso a charlas magistrales con ponentes internacionales',
  'Conexión directa con incubadoras y el ecosistema emprendedor',
  'Networking con los 50 mejores estudiantes de Arequipa',
  'Premios y oportunidades para escalar tu prototipo',
];
---

<section id="register" class="section register">
  <div class="container">
    <div class="register-card" data-reveal>
      <div class="register-bg" aria-hidden="true">
        <div class="orb-a"></div>
        <div class="orb-b"></div>
        <div class="grid-deco"></div>
      </div>

      <div class="register-grid">
        <div class="register-content">
          <span class="section-tag">Postulaciones abiertas</span>
          <h2 class="register-title">
            Postula a <span class="gradient-text">NEXIA 2026</span><br/>
            y construye con IA.
          </h2>
          <p class="register-lead">
            Estudiantes de <strong>9.°</strong> y <strong>10.° ciclo</strong> + <strong>egresados recientes</strong>
            de las principales universidades de Arequipa. Equipos interdisciplinarios de 3 a 5 integrantes.
          </p>

          <ul class="benefits">
            {benefits.map((b) => (
              <li>
                <span class="check" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {b}
              </li>
            ))}
          </ul>

          <div class="cta-row">
            <a href="mailto:nexia2026@imb.pe" class="btn btn-primary">
              Postular ahora
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="tel:+51993426785" class="btn btn-ghost">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              +51 993 426 785
            </a>
          </div>
        </div>

        <div class="register-visual">
          <div class="form-mock">
            <div class="form-row">
              <span class="form-label mono">// 01_TEAM</span>
              <span class="form-value">{`{ "name": "Tu equipo", "size": 3-5 }`}</span>
            </div>
            <div class="form-row">
              <span class="form-label mono">// 02_UNIVERSITY</span>
              <span class="form-value">universidades · arequipa</span>
            </div>
            <div class="form-row">
              <span class="form-label mono">// 03_TRACK</span>
              <span class="form-value">elige tu desafío de IA</span>
            </div>
            <div class="form-row">
              <span class="form-label mono">// 04_IDEA</span>
              <span class="form-value">describe tu impacto educativo</span>
            </div>
            <div class="form-stamp">
              <span class="stamp-dot"></span>
              <span class="mono">STATUS: OPEN · 50 SPOTS</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .register-card {
    position: relative;
    border-radius: 32px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-1);
    padding: clamp(40px, 6vw, 80px);
    box-shadow: 0 30px 100px rgba(0, 0, 0, 0.6);
  }

  .register-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .orb-a, .orb-b {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.45;
  }

  .orb-a {
    width: 400px;
    height: 400px;
    background: var(--primary);
    top: -100px;
    left: -100px;
  }

  .orb-b {
    width: 500px;
    height: 500px;
    background: var(--accent);
    bottom: -200px;
    right: -150px;
  }

  .grid-deco {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-color) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse at center, black, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black, transparent 75%);
    opacity: 0.4;
  }

  .register-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .register-title {
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 16px 0 18px;
  }

  .register-lead {
    font-size: 1rem;
    color: var(--text-dim);
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .register-lead strong {
    color: var(--text);
    font-weight: 600;
  }

  .benefits {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 24px;
    margin-bottom: 36px;
  }

  .benefits li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .check {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--grad);
    color: #ffffff;
    margin-top: 1px;
  }

  .cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Form mock */
  .form-mock {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 24px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transform: rotate(2deg);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
  }

  .form-row {
    padding: 14px 0;
    border-bottom: 1px dashed var(--border);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-row:last-of-type {
    border-bottom: none;
  }

  .form-label {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }

  .form-value {
    font-size: 14px;
    color: var(--text);
    font-weight: 500;
  }

  .form-stamp {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding: 8px 14px;
    background: var(--grad-soft);
    border: 1px solid var(--primary);
    border-radius: 999px;
    font-size: 11px;
    color: var(--primary);
    letter-spacing: 0.18em;
  }

  .stamp-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 12px var(--success);
    animation: pulse 1.5s ease-in-out infinite;
  }

  @media (max-width: 980px) {
    .register-grid { grid-template-columns: 1fr; }
    .form-mock { transform: none; max-width: 460px; }
  }

  @media (max-width: 540px) {
    .benefits { grid-template-columns: 1fr; }
  }
</style>
