---
const tracks = [
  {
    code: '01',
    name: 'AI Tutoring',
    desc: 'Asistentes personalizados que se adaptan al ritmo y estilo de aprendizaje de cada estudiante.',
    tags: ['LLM', 'Adaptive', 'NLP'],
    img: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&w=800&q=80',
  },
  {
    code: '02',
    name: 'Knowledge Engines',
    desc: 'Bibliotecas vivas: indexa contenidos universitarios y conviértelos en respuestas con citas.',
    tags: ['RAG', 'Vector', 'Search'],
    img: 'https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?auto=format&fit=crop&w=800&q=80',
  },
  {
    code: '03',
    name: 'Auto-Evaluation',
    desc: 'Modelos que retroalimentan ensayos, código y exámenes orales con justificación clara.',
    tags: ['Eval', 'Multimodal', 'Speech'],
    img: 'https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=800&q=80',
  },
  {
    code: '04',
    name: 'Inclusive AI',
    desc: 'Accesibilidad, traducción a lenguas originarias y educación sin barreras económicas.',
    tags: ['ASR', 'TTS', 'A11y'],
    img: 'https://images.unsplash.com/photo-1573164713988-8665fc963095?auto=format&fit=crop&w=800&q=80',
  },
];
---

<section id="tracks" class="section tracks">
  <div class="container">
    <div class="tracks-head" data-reveal>
      <span class="section-tag">Tracks · Categorías</span>
      <h2 class="section-title">
        4 frentes para <span class="gradient-text">transformar la educación</span>
      </h2>
      <p class="section-subtitle">
        Cada equipo elige un track y construye un prototipo funcional con impacto real.
        La IA es la herramienta. La educación, el objetivo.
      </p>
    </div>

    <div class="tracks-grid">
      {tracks.map((t, i) => (
        <article class="track" data-reveal style={`transition-delay: ${i * 100}ms`}>
          <div class="track-media">
            <img src={t.img} alt={`Inspiración visual para el track ${t.name}`} loading="lazy" />
            <div class="track-media-tint" aria-hidden="true"></div>
            <span class="track-code mono">{t.code}</span>
          </div>
          <div class="track-body">
            <h3 class="track-name">{t.name}</h3>
            <p class="track-desc">{t.desc}</p>
            <ul class="track-tags">
              {t.tags.map((tag) => <li class="mono">#{tag}</li>)}
            </ul>
            <div class="track-cta">
              <span>Ver más</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .tracks-head {
    max-width: 720px;
    margin-bottom: 40px;
  }

  .tracks-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .track {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .track:hover {
    transform: translateY(-8px);
    border-color: color-mix(in srgb, var(--primary) 60%, var(--border));
  }

  .track-media {
    position: relative;
    aspect-ratio: 16 / 11;
    overflow: hidden;
  }

  .track-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .track:hover .track-media img {
    transform: scale(1.08);
  }

  .track-media-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 30%,
      color-mix(in srgb, var(--bg-1) 80%, transparent) 100%
    ),
    linear-gradient(
      135deg,
      color-mix(in srgb, var(--primary) 35%, transparent),
      transparent 60%
    );
    mix-blend-mode: multiply;
  }

  .track-code {
    position: absolute;
    top: 16px;
    left: 16px;
    font-size: 12px;
    color: var(--primary);
    letter-spacing: 0.18em;
    font-weight: 700;
    background: rgba(0, 0, 0, 0.6);
    padding: 6px 10px;
    border-radius: 6px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .track-body {
    padding: 22px 22px 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .track-name {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .track-desc {
    font-size: 14px;
    color: var(--text-dim);
    line-height: 1.55;
    margin-bottom: 18px;
    flex: 1;
  }

  .track-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 18px;
  }

  .track-tags li {
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 6px;
    background: var(--surface-strong);
    border: 1px solid var(--border);
    color: var(--primary);
  }

  .track-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    color: var(--primary);
    transition: gap 0.3s ease;
  }

  .track:hover .track-cta {
    gap: 12px;
  }

  @media (max-width: 1080px) {
    .tracks-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .tracks-grid { grid-template-columns: 1fr; }
  }
</style>
