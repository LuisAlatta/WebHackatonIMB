---
---

<section id="top" class="hero">
  <div class="container hero-container">
    <div class="hero-content" data-reveal>
      <div class="hero-badge">
        <span class="dot"></span>
        <span class="mono">29 — 31 · MAYO · 2026</span>
        <span class="badge-divider">·</span>
        <span>Arequipa, Perú</span>
      </div>

      <h1 class="hero-title">
        <span class="hero-eyebrow">BUILD WITH AI</span>
        <span class="hero-mega gradient-text">NEXIA</span>
        <span class="hero-year">
          <span class="year-digit">2</span><span class="year-digit">0</span><span class="year-digit">2</span><span class="year-digit">6</span>
        </span>
      </h1>

      <p class="hero-lead">
        El <strong>primer hackathon universitario presencial de Arequipa</strong>
        100% enfocado en el uso de <strong>Inteligencia Artificial</strong>
        para transformar la educación.
      </p>

      <div class="hero-cta">
        <a href="#register" class="btn btn-primary">
          Postular ahora
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="#about" class="btn btn-ghost">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Ver detalles
        </a>
      </div>

      <ul class="hero-meta">
        <li>
          <span class="meta-num">50</span>
          <span class="meta-label">participantes</span>
        </li>
        <li>
          <span class="meta-num">10</span>
          <span class="meta-label">equipos</span>
        </li>
        <li>
          <span class="meta-num">3</span>
          <span class="meta-label">días</span>
        </li>
        <li>
          <span class="meta-num">150+</span>
          <span class="meta-label">en charlas</span>
        </li>
      </ul>
    </div>

    <aside class="hero-visual" aria-hidden="true">
      <div class="terminal glass">
        <div class="terminal-bar">
          <span class="dot-r"></span>
          <span class="dot-y"></span>
          <span class="dot-g"></span>
          <span class="terminal-title mono">~/nexia2026 — bash</span>
        </div>
        <div class="terminal-body mono">
          <div class="line"><span class="prompt">$</span> nexia init <span class="arg">--mode hackathon</span></div>
          <div class="line out">→ Booting <span class="hl">NEXIA 2026</span> in Arequipa…</div>
          <div class="line"><span class="prompt">$</span> ai.educate(<span class="str">'students'</span>)</div>
          <div class="line out">✓ 50 estudiantes seleccionados</div>
          <div class="line out">✓ 10 equipos · 3 días intensivos</div>
          <div class="line"><span class="prompt">$</span> deploy<span class="arg">.idea</span>(<span class="str">'impact'</span>)</div>
          <div class="line out blink">▍</div>
        </div>
      </div>

      <div class="floating-card glass card-1">
        <span class="card-tag">EDU · IA</span>
        <span class="card-title">Tutor IA</span>
        <span class="card-desc">Personaliza el aprendizaje en tiempo real</span>
      </div>

      <div class="floating-card glass card-2">
        <span class="card-tag">RAG · LLM</span>
        <span class="card-title">Bibliotecas vivas</span>
        <span class="card-desc">Conoce, busca, aprende.</span>
      </div>

      <div class="circuit" aria-hidden="true"></div>
    </aside>
  </div>

  <div class="hero-marquee" aria-hidden="true">
    <div class="marquee-track">
      {Array.from({ length: 2 }).map(() => (
        <div class="marquee-row">
          <span>· INTELIGENCIA ARTIFICIAL</span>
          <span>· EDUCACIÓN</span>
          <span>· HACKATHON</span>
          <span>· PROTOTIPOS</span>
          <span>· MENTORÍA</span>
          <span>· INNOVACIÓN</span>
          <span>· AREQUIPA 2026</span>
          <span>· BUILD WITH AI</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 120px 0 32px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 18px;
    border: 1px solid var(--border);
    background: var(--surface);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 999px;
    font-size: 12px;
    color: var(--text-dim);
    margin-bottom: 28px;
  }

  .hero-badge .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 12px var(--success);
    animation: pulse 1.6s ease-in-out infinite;
  }

  .badge-divider {
    color: var(--border);
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 0 0 28px;
  }

  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.85rem, 1.4vw, 1.05rem);
    font-weight: 500;
    letter-spacing: 0.4em;
    color: var(--text-dim);
    margin-bottom: 8px;
  }

  .hero-mega {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 800;
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-shadow: 0 0 80px color-mix(in srgb, var(--primary) 30%, transparent);
  }

  .hero-year {
    display: flex;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    color: var(--text-dim);
    letter-spacing: 0.4em;
    margin-top: 12px;
  }

  .year-digit {
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
  }

  .hero-lead {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    color: var(--text-dim);
    max-width: 580px;
    line-height: 1.6;
    margin-bottom: 36px;
  }

  .hero-lead strong {
    color: var(--text);
    font-weight: 600;
  }

  .hero-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .hero-meta {
    list-style: none;
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }

  .hero-meta li {
    display: flex;
    flex-direction: column;
    border-left: 2px solid var(--primary);
    padding-left: 14px;
  }

  .meta-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    line-height: 1;
    color: var(--text);
  }

  .meta-label {
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-top: 4px;
  }

  /* Visual side */
  .hero-visual {
    position: relative;
    height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .terminal {
    width: 100%;
    max-width: 460px;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px var(--border);
    transform: rotate(-2deg);
    animation: drift 8s ease-in-out infinite;
  }

  @keyframes drift {
    0%, 100% { transform: rotate(-2deg) translateY(0); }
    50% { transform: rotate(-1deg) translateY(-10px); }
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 16px;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid var(--border);
  }

  .terminal-bar > span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }

  .terminal-title {
    margin-left: 12px;
    font-size: 12px;
    color: var(--text-dim);
  }

  .terminal-body {
    padding: 22px 20px;
    font-size: 13px;
    line-height: 1.9;
    background: rgba(0, 0, 0, 0.25);
    min-height: 240px;
  }

  .line .prompt {
    color: var(--success);
    margin-right: 8px;
  }

  .line .arg { color: var(--accent); }
  .line .str { color: var(--primary); }
  .line .hl  { color: var(--primary); font-weight: 700; }
  .line.out  { color: var(--text-dim); padding-left: 18px; }
  .line.out.blink::after {
    content: '';
  }
  .line.blink {
    color: var(--primary);
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  /* Floating cards */
  .floating-card {
    position: absolute;
    padding: 16px 20px;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 220px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    animation: bob 6s ease-in-out infinite;
  }

  .card-1 {
    top: 8%;
    right: 0%;
    animation-delay: -2s;
  }

  .card-2 {
    bottom: 4%;
    left: 0;
    animation-delay: -4s;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .card-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--primary);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 700;
  }

  .card-desc {
    font-size: 12px;
    color: var(--text-dim);
  }

  /* Circuit decoration */
  .circuit {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 30%, var(--primary) 0%, transparent 1%),
      radial-gradient(circle at 70% 70%, var(--accent) 0%, transparent 1%),
      radial-gradient(circle at 50% 20%, var(--primary-2) 0%, transparent 1%);
    background-size: 60px 60px;
    opacity: 0.3;
    z-index: -1;
  }

  /* Marquee */
  .hero-marquee {
    margin-top: 48px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    background: var(--surface);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 40s linear infinite;
  }

  .marquee-row {
    display: flex;
    gap: 64px;
    padding: 18px 32px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .marquee-row span:nth-child(odd) {
    color: var(--text);
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (max-width: 980px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-visual {
      height: 440px;
    }
    .floating-card { min-width: 180px; padding: 12px 16px; }
    .card-1 { right: 4%; }
  }

  @media (max-width: 600px) {
    .hero-meta { gap: 18px; }
    .hero-visual { height: 380px; }
    .terminal { max-width: 320px; }
    .terminal-body { font-size: 11px; }
    .floating-card { display: none; }
  }
</style>
